# Facebook Page Publisher — copy this file to your dotenv location
# (default: ~/.hermes/.env, override with --dotenv <path>)

# --- Required ---
FB_APP_ID=your_app_id
FB_APP_SECRET=your_app_secret
FB_PAGE_ID=your_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token
FB_LONG_LIVED_USER_TOKEN=your_long_lived_user_token

# --- Optional ---
# Graph API version (default: v25.0)
FB_GRAPH_VERSION=v25.0

# Videos >= this many bytes use Meta's Resumable Upload protocol
# (default: 104857600 = 100 MB). Lower it to force resumable on smaller test files.
FB_RESUMABLE_THRESHOLD=104857600

# Chunk size (bytes) for resumable transfer phase (default: 8388608 = 8 MB)
FB_RESUMABLE_CHUNK=8388608
